# Canonical site URL (metadata, JSON-LD, sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.ctstours.co.nz

# Supabase (public + server-only service role for /admin image APIs)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin image CMS (MVP: shared secret; httpOnly cookie + x-admin-key)
ADMIN_SECRET_KEY=use-a-long-random-string

# Resend — required for /api/tour-enquiry and /api/send-itinerary
RESEND_API_KEY=re_xxxxxxxx

# Optional: inbox for tour enquiries (defaults to info@ctstours.co.nz)
# ENQUIRY_NOTIFY_EMAIL=

# Google Tag Manager ID
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4 Measurement ID (if using GA4 directly)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Ads Conversion IDs (optional, for direct Google Ads tracking)
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=your_conversion_label

# Password gate for /marketing/campaign (min 12 chars). If unset, campaign board stays public (local dev).
# Render: add as secret env; share this value with clients as the login password.
# MARKETING_PLAN_ACCESS_KEY=use-a-long-random-string-here
