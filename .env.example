# Canonical site URL (metadata, JSON-LD, sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.ctstours.co.nz

# Supabase (public + server-only service role for /admin image APIs)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin image CMS (MVP: shared secret; httpOnly cookie + x-admin-key)
ADMIN_SECRET_KEY=use-a-long-random-string

# Resend — required for /api/tour-enquiry, /api/tailor-made-enquiry, /api/contact, and /api/send-itinerary
RESEND_API_KEY=re_xxxxxxxx

# Optional: inbox for tour + contact form notifications (defaults to info@ctstours.co.nz)
# ENQUIRY_NOTIFY_EMAIL=

# Google Tag Manager ID
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Google Analytics 4 Measurement ID (if using GA4 directly)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Ads Conversion IDs (optional, for direct Google Ads tracking)
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXX
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=your_conversion_label

# Password gate for /marketing/campaign (min 12 chars). If unset, campaign board stays public (local dev).
# Render: add as secret env; share this value with clients as the login password.
# MARKETING_PLAN_ACCESS_KEY=use-a-long-random-string-here

# Newsletter — Mailchimp integration (double opt-in, subscriber management)
# API key format: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us19  (datacenter suffix after the dash)
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us19
MAILCHIMP_AUDIENCE_ID=xxxxxxxxxx
MAILCHIMP_DATACENTER=us19

# Wavespeed AI — image generation for social automation (Phase 2)
# Used by: scripts/social-image-generator.* (planned)
WAVESPEED_API_KEY=apikey-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GA4 Data API — for /marketing/campaign/data dashboard (server-side reporting)
# Property ID: 9-digit numeric ID from GA4 Admin → Property details
#              (NOT the G-XXX measurement ID, which is for the frontend beacon)
GA4_PROPERTY_ID=123456789
# Service account credentials — from the JSON key downloaded in GCP IAM → Service Accounts.
# The same service account must be added as a Viewer in GA4 Admin → Property access management.
GOOGLE_SERVICE_ACCOUNT_EMAIL=cts-ga4-reader@your-project.iam.gserviceaccount.com
# Paste the entire private_key string from the JSON, keeping the literal \n escapes intact.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# Optional: bearer token to protect POST /api/ga4/sync (falls back to GSC_SYNC_SECRET if unset).
# GA4_SYNC_SECRET=long-random-string
